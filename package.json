{
  "name": "@zhangyx1998/claude-resume",
  "version": "0.0.0",
  "description": "Auto resume claude code session at scheduled time",
  "type": "module",
  "private": true,
  "bin": {
    "claude-resume": "dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "run-s build:check build:rollup",
    "build:check": "tsc --noEmit",
    "build:rollup": "rollup --config rollup.config.ts --configPlugin esbuild",
    "build:debug": "rollup --config rollup.config.ts --configPlugin esbuild --configDebug",
    "dev": "npm run build:debug && node dist/index.js",
    "test": "node dist/index.js --help"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "resume",
    "quota",
    "scheduler"
  ],
  "author": "Yuxuan Zhang",
  "license": "MIT",
  "homepage": "https://github.com/zhangyx1998/claude-resume#readme",
  "bugs": {
    "url": "https://github.com/zhangyx1998/claude-resume/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangyx1998/claude-resume.git"
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^26.1.0",
    "esbuild": "^0.25.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "rollup": "^4.30.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "^5.7.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
